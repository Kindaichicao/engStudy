# Copy this file to `.env` and fill in your real key.
# Both Gemini and Groq are FREE — pick one (or set both).

# Server settings
PORT=8765

# Optional: name your study profile (defaults to "me"). All browsers connecting
# to this server share the same profile, so single-user setup is automatic.
# USER_ID=me

# ===== Storage backend =====
# Default "local" → writes data/progress.json on the server filesystem.
# "drive"          → writes a JSON file in Google Drive (free + persistent).
STORAGE_BACKEND=local

# ----- Drive backend settings (only used when STORAGE_BACKEND=drive) -----
# Either set the file path (recommended for local dev) ...
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./gcp-sa.json
# ... or paste the SA JSON base64-encoded (recommended for Koyeb / cloud env vars):
#   base64 -i gcp-sa.json | tr -d '\n'   (macOS/Linux)
# GOOGLE_SERVICE_ACCOUNT_KEY_B64=

# Drive folder ID where progress.json will live (share this folder with the SA email).
# GOOGLE_DRIVE_FOLDER_ID=
# Optional override of the file name inside the folder.
# GOOGLE_DRIVE_FILE_NAME=progress.json
# Optional debounce window in ms (writes are coalesced within this window).
# DRIVE_DEBOUNCE_MS=2000

# Default provider when both are configured: "gemini" or "groq"
COACH_PROVIDER=gemini

# Google Gemini (free tier — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Groq (free tier, very fast Llama/Mixtral — https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
